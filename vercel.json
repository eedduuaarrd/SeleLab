{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.selelab.xyz" }],
      "destination": "https://selelab.xyz/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
